{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": false,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/*"],
      "@social/ui-shared": ["apps/web/components/ui-shared/"],
      "@social/utils-shared": ["apps/web/components/utils-shared/"],
      "@app/*": ["apps/web/app/*"],
      "@components/*": ["apps/web/components/*"],
      "@hooks/*": ["apps/web/app/hooks/*"]
    },
    "noImplicitAny": false
  },
  "include": ["apps/web/components/utils-shared/types"],
  "exclude": ["node_modules", "tmp"]
}
