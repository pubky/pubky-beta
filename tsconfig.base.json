{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": false,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/web/*"],
      "@social/ui-shared": ["libs/ui-shared/src/index.ts"],
      "@social/utils-shared": ["libs/utils-shared/src/index.ts"]
    },
    "noImplicitAny": false
  },
  "include": ["libs/utils-shared/src/types"],
  "exclude": ["node_modules", "tmp"]
}
