{
  "compileOnSave": false,
  "compilerOptions": {
    "allowJs": false,
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@social/ui-shared": ["src/components/ui-shared/"],
      "@social/utils-shared": ["src/components/utils-shared/"],
      "@app/*": ["src/app/*"],
      "@components/*": ["src/components/*"],
      "@hooks/*": ["src/app/hooks/*"]
    },
    "noImplicitAny": false
  },
  "include": ["src/components/utils-shared/types"],
  "exclude": ["node_modules", "tmp"]
}
