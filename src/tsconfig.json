{
  "extends": "..\/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "../next.config.js",
    "../postcss.config.js",
    "../tailwind.config.js"
  ],
  "exclude": [
, "../index.d.ts"    "node_modules",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "app/profile/components/_ContactsProfile/_Contact.tsx"
  ]
}
